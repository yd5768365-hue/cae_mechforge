{
  "name": "mechforge-gui",
  "version": "0.5.0",
  "description": "MechForge AI PyWebView Desktop Application",
  "main": "desktop_app.py",
  "scripts": {
    "start": "python desktop_app.py",
    "start:debug": "python desktop_app.py --debug",
    "dev": "python desktop_app.py --debug",
    "build": "python build.py --build",
    "build:clean": "python build.py",
    "build:optimize": "python build.py --optimize",
    "clean": "python build.py --clean",
    "lint": "eslint app/**/*.js core/**/*.js services/**/*.js",
    "lint:fix": "eslint app/**/*.js core/**/*.js services/**/*.js --fix",
    "lint:css": "stylelint css/**/*.css",
    "quality": "node scripts/code-quality.js",
    "quality:check": "npm run lint && npm run quality",
    "format": "prettier --write \"**/*.js\" \"**/*.css\" \"**/*.html\"",
    "format:check": "prettier --check \"**/*.js\" \"**/*.css\" \"**/*.html\"",
    "test": "node tests/test-framework.js",
    "test:browser": "start tests/index.html",
    "test:coverage": "npm test -- --coverage",
    "optimize": "python build.py --optimize",
    "check": "npm run lint && npm run format:check && npm run quality:check",
    "fix": "npm run lint:fix && npm run format",
    "dev:server": "node scripts/dev-server.js",
    "analyze": "node scripts/analyze-bundle.js",
    "check:deps": "node scripts/check-deps.js",
    "test:unit": "node tests/test-framework.js",
    "test:browser": "start tests/test-runner.html",
    "icons": "node scripts/generate-icons.js"
  },
  "keywords": [
    "mechforge",
    "ai",
    "desktop",
    "pywebview",
    "llm",
    "chat"
  ],
  "author": "MechForge Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/yd5768365-hue/mechforge"
  },
  "devDependencies": {
    "eslint": "^8.57.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}