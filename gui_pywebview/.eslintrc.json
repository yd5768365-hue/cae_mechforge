{
  "env": {
    "browser": true,
    "es2022": true
  },
  "extends": [
    "eslint:recommended"
  ],
  "parserOptions": {
    "ecmaVersion": 2022,
    "sourceType": "script"
  },
  "globals": {
    "window": "readonly",
    "document": "readonly",
    "console": "readonly",
    "setTimeout": "readonly",
    "clearTimeout": "readonly",
    "setInterval": "readonly",
    "clearInterval": "readonly",
    "Math": "readonly",
    "Date": "readonly",
    "fetch": "readonly",
    "AbortSignal": "readonly",
    "TextDecoder": "readonly",
    "JSON": "readonly",
    "Error": "readonly",
    "alert": "readonly",
    "requestAnimationFrame": "readonly",
    "cancelAnimationFrame": "readonly",
    "requestIdleCallback": "readonly",
    "IntersectionObserver": "readonly",
    "MutationObserver": "readonly",
    "PerformanceObserver": "readonly",
    "ResizeObserver": "readonly",
    "CustomEvent": "readonly",
    "WeakMap": "readonly",
    "WeakSet": "readonly",
    "Map": "readonly",
    "Set": "readonly",
    "Promise": "readonly",
    "performance": "readonly",
    "localStorage": "readonly",
    "sessionStorage": "readonly",
    "navigator": "readonly",
    "location": "readonly",
    "history": "readonly",
    "eventBus": "readonly",
    "Events": "readonly",
    "apiClient": "readonly",
    "APIClient": "readonly",
    "AIService": "readonly",
    "ConfigService": "readonly",
    "Utils": "readonly",
    "Particles": "readonly",
    "WindowControl": "readonly",
    "Mascot": "readonly",
    "ChatUI": "readonly",
    "ChatHandler": "readonly",
    "KnowledgeUI": "readonly",
    "CAEWorkbench": "readonly",
    "APISwitcher": "readonly",
    "AppState": "readonly",
    "ExpLib": "readonly",
    "ModuleLoader": "readonly",
    "EventManager": "readonly",
    "PerformanceMonitor": "readonly",
    "ThemeManager": "readonly",
    "StatusBarManager": "readonly",
    "ChatFeatures": "readonly",
    "Markdown": "readonly",
    "Logger": "readonly",
    "Storage": "readonly",
    "ErrorHandler": "readonly"
  },
  "rules": {
    "indent": ["error", 2, { "SwitchCase": 1 }],
    "linebreak-style": ["error", "unix"],
    "quotes": ["error", "single", { "avoidEscape": true }],
    "semi": ["error", "always"],
    "no-unused-vars": ["warn", { 
      "argsIgnorePattern": "^_|^e$",
      "varsIgnorePattern": "^_|^I18N$",
      "caughtErrorsIgnorePattern": "^_|^e$"
    }],
    "no-console": ["warn", { "allow": ["log", "warn", "error", "info"] }],
    "prefer-const": "error",
    "no-var": "error",
    "eqeqeq": ["error", "always", { "null": "ignore" }],
    "curly": ["error", "multi-line", "consistent"],
    "brace-style": ["error", "1tbs", { "allowSingleLine": true }],
    "comma-dangle": ["error", "never"],
    "comma-spacing": ["error", { "before": false, "after": true }],
    "key-spacing": ["error", { "beforeColon": false, "afterColon": true }],
    "keyword-spacing": ["error", { "before": true, "after": true }],
    "space-before-blocks": "error",
    "space-before-function-paren": ["error", {
      "anonymous": "always",
      "named": "never",
      "asyncArrow": "always"
    }],
    "space-infix-ops": "error",
    "arrow-spacing": "error",
    "no-multiple-empty-lines": ["error", { "max": 2, "maxEOF": 1 }],
    "no-trailing-spaces": "error",
    "eol-last": ["error", "always"],
    "no-tabs": "error",
    "no-mixed-spaces-and-tabs": "error",
    "no-multi-spaces": ["error", { "ignoreEOLComments": true }],
    "no-whitespace-before-property": "error",
    "block-spacing": "error",
    "array-bracket-spacing": ["error", "never"],
    "object-curly-spacing": ["error", "always"],
    "computed-property-spacing": ["error", "never"],
    "func-call-spacing": ["error", "never"],
    "rest-spread-spacing": ["error", "never"],
    "template-curly-spacing": ["error", "never"],
    "no-duplicate-imports": "error",
    "no-useless-return": "error",
    "no-useless-concat": "error",
    "no-useless-escape": "error",
    "no-useless-rename": "error",
    "prefer-arrow-callback": "error",
    "prefer-template": "warn",
    "prefer-spread": "error",
    "prefer-rest-params": "error",
    "prefer-destructuring": ["warn", { "object": true, "array": false }],
    "prefer-numeric-literals": "error",
    "prefer-exponentiation-operator": "error",
    "no-eval": "error",
    "no-implied-eval": "error",
    "no-new-func": "error",
    "no-script-url": "error",
    "no-void": "error",
    "no-with": "error",
    "no-undef-init": "error",
    "no-undefined": "off",
    "no-shadow": ["warn", { "builtinGlobals": false, "hoist": "functions" }],
    "no-shadow-restricted-names": "error",
    "no-use-before-define": ["error", { "functions": false, "classes": false }],
    "no-redeclare": "error",
    "no-global-assign": "error",
    "no-self-assign": "error",
    "no-self-compare": "error",
    "no-sequences": "error",
    "no-throw-literal": "error",
    "no-unmodified-loop-condition": "warn",
    "no-unused-expressions": ["error", { "allowShortCircuit": true, "allowTernary": true }],
    "no-useless-call": "error",
    "no-useless-catch": "error",
    "no-useless-constructor": "error",
    "no-param-reassign": ["warn", { "props": false }],
    "consistent-return": "warn",
    "dot-notation": "error",
    "no-alert": "off",
    "no-debugger": "warn",
    "no-empty": ["error", { "allowEmptyCatch": true }],
    "no-extra-boolean-cast": "error",
    "no-extra-semi": "error",
    "no-func-assign": "error",
    "no-invalid-regexp": "error",
    "no-irregular-whitespace": "error",
    "no-lonely-if": "warn",
    "no-nested-ternary": "off",
    "no-proto": "error",
    "no-return-assign": ["error", "except-parens"],
    "no-return-await": "error",
    "no-unneeded-ternary": "warn",
    "no-unused-labels": "error",
    "require-await": "warn",
    "spaced-comment": ["warn", "always", { "markers": ["/", "!", "#"] }],
    "yoda": ["error", "never", { "exceptRange": true }],
    "valid-typeof": ["error", { "requireStringLiterals": true }]
  },
  "overrides": [
    {
      "files": ["**/*.test.js", "**/tests/**/*.js"],
      "env": {
        "jest": true,
        "node": true
      },
      "rules": {
        "no-console": "off"
      }
    }
  ],
  "ignorePatterns": [
    "node_modules/",
    "dist/",
    "build/",
    "__pycache__/",
    "*.min.js"
  ]
}
